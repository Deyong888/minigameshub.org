---
import { Icon } from 'astro-icon/components';
---

<div id="pwa-install-toast" class="fixed bottom-4 left-4 z-50 hidden transform transition-transform duration-300 translate-y-full print:hidden">
  <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-2xl p-4 max-w-sm flex items-start gap-4">
    <div class="bg-blue-100 dark:bg-blue-900 p-2 rounded-full shrink-0">
      <Icon name="tabler:download" class="w-6 h-6 text-blue-600 dark:text-blue-300" />
    </div>
    <div class="flex-1">
      <h3 class="font-bold text-gray-900 dark:text-white text-sm mb-1">Install App</h3>
      <p class="text-gray-600 dark:text-gray-300 text-xs mb-3">Install MiniGamesHub for a better experience and offline play.</p>
      <div class="flex gap-2">
        <button id="pwa-install-btn" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-1.5 px-3 rounded transition-colors">
          Install
        </button>
        <button id="pwa-dismiss-btn" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 text-xs font-medium py-1.5 px-3">
          Later
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  let deferredPrompt: any;
  const toast = document.getElementById('pwa-install-toast');
  const installBtn = document.getElementById('pwa-install-btn');
  const dismissBtn = document.getElementById('pwa-dismiss-btn');

  // Check if user has dismissed before
  const isDismissed = localStorage.getItem('pwa_dismissed');

  window.addEventListener('beforeinstallprompt', (e) => {
    // Prevent Chrome 67 and earlier from automatically showing the prompt
    e.preventDefault();
    // Stash the event so it can be triggered later.
    deferredPrompt = e;
    
    // Update UI notify the user they can add to home screen
    if (!isDismissed) {
      showInstallPromotion();
    }
  });

  function showInstallPromotion() {
    if (toast) {
      toast.classList.remove('hidden');
      // Small delay to allow display:block to apply before transition
      setTimeout(() => {
        toast.classList.remove('translate-y-full');
      }, 100);
    }
  }

  function hideInstallPromotion() {
    if (toast) {
      toast.classList.add('translate-y-full');
      setTimeout(() => {
        toast.classList.add('hidden');
      }, 300);
    }
  }

  installBtn?.addEventListener('click', async () => {
    hideInstallPromotion();
    // Show the prompt
    if (deferredPrompt) {
      deferredPrompt.prompt();
      // Wait for the user to respond to the prompt
      const { outcome } = await deferredPrompt.userChoice;
      console.log(`User response to the install prompt: ${outcome}`);
      deferredPrompt = null;
    }
  });

  dismissBtn?.addEventListener('click', () => {
    hideInstallPromotion();
    // Save dismissal preference
    localStorage.setItem('pwa_dismissed', 'true');
  });

  window.addEventListener('appinstalled', () => {
    hideInstallPromotion();
    deferredPrompt = null;
    console.log('PWA was installed');
  });
</script>
