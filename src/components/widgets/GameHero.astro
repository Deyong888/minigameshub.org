---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { featuredGames } from '~/data/games';
import type { Game } from '~/types/game';
import { useTranslations } from '~/utils/i18n';

interface Props {
  id?: string;
  isDark?: boolean;
  classes?: Record<string, string>;
  bg?: string;
  initialGame?: Game;
}

const lang = Astro.currentLocale || 'en';
const t = useTranslations(lang as any);

const {
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
  initialGame = featuredGames[0] // Default to first featured game
} = Astro.props;

const games = featuredGames.slice(0, 10);
const gameLinkPrefix = lang === 'es' ? '/es/game/' : '/game/';
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <div class="relative w-full aspect-video bg-gray-900 rounded-lg overflow-hidden shadow-2xl">
    <!-- Mystery Box Trigger -->
    <div class="absolute top-4 right-4 z-20">
      <a href={lang === 'es' ? '/es/surprise' : '/surprise'} class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded-full shadow-lg transition transform hover:scale-105 animate-bounce flex items-center gap-2 no-underline">
        <span>🎁</span> <span class="hidden sm:inline">{t('hero.surprise')}</span>
      </a>
    </div>

    <!-- Game Container -->
    <div 
      class="w-full h-full flex flex-col relative" 
      id="heroGameContainer"
      data-game-link-prefix={gameLinkPrefix}
      data-now-playing-text={t('hero.nowPlaying')}
      data-initial-slug={initialGame?.slug}
      data-initial-id={initialGame?.id}
    >
      <iframe 
        id="heroFrame"
        src={initialGame?.url || 'https://games.gamepix.com/play/slither-io?sid=GM8A7'} 
        title={initialGame?.title || 'Game'}
        class="w-full flex-grow border-none"
        allowfullscreen
        sandbox="allow-scripts allow-same-origin allow-popups"
      ></iframe>
      
      <!-- Controls Bar -->
      <div class="bg-gray-800 p-3 flex justify-between items-center text-white z-20 relative">
        <span id="currentGameTitle" class="font-bold ml-2 truncate max-w-[50%]">{t('hero.nowPlaying')} {initialGame?.title || 'Loading...'}</span>
        <div class="flex gap-2 shrink-0">
          <button id="heroFavoriteBtn" class="px-3 py-1 bg-pink-600 rounded hover:bg-pink-700 text-sm" title="Add to Favorites">❤️</button>
          <a id="gameDetailsLink" href={`${gameLinkPrefix}${initialGame ? `${initialGame.id}-${initialGame.slug}` : '#'}`} class="px-3 py-1 bg-green-600 rounded hover:bg-green-700 text-sm hidden sm:inline-block no-underline text-white" title="Game Details">ℹ️ {t('hero.details')}</a>
          <button id="bossKey" class="px-3 py-1 bg-red-600 rounded hover:bg-red-700 text-sm" title="Boss Key (ESC)">🚨 {t('hero.bossKey')} (ESC)</button>
          <button id="fullscreenBtn" class="px-3 py-1 bg-blue-600 rounded hover:bg-blue-700 text-sm" title="Fullscreen">⛶ {t('hero.fullscreen')}</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Play Bar -->
  <div class="mt-4 overflow-x-auto p-4 bg-gray-900 rounded-lg scrollbar-hide">
    <h3 class="text-white text-sm mb-2 font-bold">{t('hero.trending')}</h3>
    <div class="flex gap-4 pb-2">
        {games.map((game) => (
            <div 
                class="w-32 h-20 bg-gray-700 rounded flex-shrink-0 cursor-pointer hover:opacity-80 transition relative overflow-hidden group game-thumb"
                data-url={game.url}
                data-title={game.title}
                data-slug={game.slug}
                data-id={game.id}
            >
                <img src={game.thumbnail} alt={game.title} class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-30 transition flex items-center justify-center">
                    <span class="text-white opacity-0 group-hover:opacity-100 font-bold text-xs px-1 text-center shadow-black drop-shadow-md">{game.title}</span>
                </div>
            </div>
        ))}
    </div>
  </div>
</WidgetWrapper>

<script>
  import { toggleFavorite, isFavorite, addToHistory } from '~/stores/gameState';

  const initGameHero = () => {
    // Elements
    const heroGameContainer = document.getElementById('heroGameContainer');
    const heroFrame = document.getElementById('heroFrame') as HTMLIFrameElement | null;
    const fullscreenBtn = document.getElementById('fullscreenBtn');
    const heroFavoriteBtn = document.getElementById('heroFavoriteBtn');
    const bossKeyBtn = document.getElementById('bossKey');
    const gameThumbs = document.querySelectorAll('.game-thumb');
    const gameTitle = document.getElementById('currentGameTitle');
    const detailsLink = document.getElementById('gameDetailsLink') as HTMLAnchorElement | null;
    
    if (!heroGameContainer) return;

    const { gameLinkPrefix, nowPlayingText, initialSlug } = (heroGameContainer as HTMLElement).dataset;

    // State
    let currentSlug = initialSlug || document.querySelector('.game-thumb')?.getAttribute('data-slug') || 'slither-io';

    // Boss Key
    const activateBossKey = () => {
        window.location.href = 'https://google.com';
    };

    document.onkeydown = (e) => {
      if (e.key === 'Escape') {
        activateBossKey();
      }
    };

    if (bossKeyBtn) {
        bossKeyBtn.onclick = activateBossKey;
    }

    // Fullscreen
    if (fullscreenBtn && heroFrame) {
        fullscreenBtn.onclick = () => {
            if (heroFrame.requestFullscreen) {
                heroFrame.requestFullscreen();
            }
        };
    }

    // Favorite Logic
    const updateFavoriteBtn = () => {
      if (!heroFavoriteBtn) return;
      const isFav = isFavorite(currentSlug);
      heroFavoriteBtn.textContent = isFav ? '❤️' : '🤍';
      heroFavoriteBtn.title = isFav ? 'Remove from Favorites' : 'Add to Favorites';
    };

    if (heroFavoriteBtn) {
        heroFavoriteBtn.onclick = () => {
            toggleFavorite(currentSlug);
            updateFavoriteBtn();
        };
    }

    // Quick Play
    gameThumbs.forEach(thumb => {
      (thumb as HTMLElement).onclick = () => {
          const url = thumb.getAttribute('data-url');
          const title = thumb.getAttribute('data-title');
          const slug = thumb.getAttribute('data-slug');
          const id = thumb.getAttribute('data-id');
          
          if (heroFrame && url && slug) {
              heroFrame.src = url;
              currentSlug = slug;
              if (gameTitle) gameTitle.textContent = `${nowPlayingText} ${title}`;
              if (detailsLink) detailsLink.href = `${gameLinkPrefix}${id}-${slug}`;
              
              addToHistory(slug);
              updateFavoriteBtn();
          }
      };
    });
    
    // Initial Check
    updateFavoriteBtn();
  };

  // Run on initial load and view transitions
  document.addEventListener('astro:page-load', initGameHero);
</script>
