---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { arcadeRetroGames } from '~/data/games';

const metadata = {
  title: 'Retro Arcade Games - Pixel Perfect',
  description: 'Pixel art and chiptunes. Dive into retro arcade goodness.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Retro Arcade Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/arcade-games/retro",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": arcadeRetroGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/arcade-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary md:ml-2 dark:text-gray-400 dark:hover:text-white">Arcade Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Retro</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Retro Arcade Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Nostalgic games with pixel-perfect art.
    </p>
    <GameGrid games={arcadeRetroGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Pixel Perfect Nostalgia Trip</h2>
      <p>
        If you love the look of big chunky pixels and the sound of synthesized chiptunes, you're in the right place. Our Retro Arcade Games celebrate the aesthetic of the 8-bit and 16-bit eras.
        These aren't just old games; many are modern "neo-retro" titles created by indie developers who love the style.
      </p>
      
      <h3>Why We Love Retro</h3>
      <ul>
        <li><strong>Artistic Style:</strong> Pixel art is a timeless medium that allows for incredible creativity.</li>
        <li><strong>Soundtrack:</strong> Catchy, loopable music that gets stuck in your head in the best way.</li>
        <li><strong>Pure Gameplay:</strong> Stripped back to the essentials, with no unnecessary fluff.</li>
      </ul>
      
      <h3>A Love Letter to the Past</h3>
      <p>
        Playing these games is like stepping into a time machine. They capture the imagination and charm of a simpler time in technology.
      </p>
    </div>
  </section>
</Layout>
