---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { noDownloadGames } from '~/data/games';

const metadata = {
  title: 'Zero Install Games - No Setup Required | MiniGamesHub',
  description: 'Enjoy high-quality games without installing anything on your computer. Zero install games keep your device clean and secure.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Zero Install Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/no-download-games/zero-install",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": noDownloadGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/no-download-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">No Download Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Zero Install</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Zero Install Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Keep your device clean. Just play.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>Why Choose Zero Install?</h3>
      <p>Installing games can clutter your hard drive and pose security risks. Zero Install games run entirely in your browser's sandbox, keeping your computer safe and your storage free.</p>
      <ul>
        <li><strong>Security:</strong> No executable files to run on your system.</li>
        <li><strong>Storage:</strong> Save gigabytes of space on your hard drive.</li>
        <li><strong>Clean:</strong> No leftover files or registry entries when you're done.</li>
      </ul>
    </div>

    <GameGrid games={noDownloadGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Keep Your PC Clean with Zero Install Games</h2>
      <p>
        Every piece of software you install slows down your computer over time. Zero Install games are the solution. They run entirely within your web browser's secure environment, leaving no trace on your system once you close the tab.
        This is the cleanest, safest way to enjoy gaming on your personal or work computer.
      </p>
      
      <h3>Security and Performance Benefits</h3>
      <ul>
        <li><strong>Sandboxed Environment:</strong> Browser games cannot access your personal files or system settings.</li>
        <li><strong>No Background Processes:</strong> Unlike installed games, these won't run updaters or launchers in the background.</li>
        <li><strong>Always Up to Date:</strong> You are always playing the latest version from the server, with no manual patching required.</li>
      </ul>
      
      <h3>Ideal for Low-End Hardware</h3>
      <p>
        Since these games rely on the browser engine, they are often much more lightweight than standalone applications, making them perfect for older laptops or Chromebooks.
      </p>
    </div>
  </section>
</Layout>
