---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { noDownloadGames } from '~/data/games';

const metadata = {
  title: 'Instant Play Games - No Download, No Wait | MiniGamesHub',
  description: 'Jump straight into the action with our instant play games. No download, no installation, just click and play. Perfect for quick breaks.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Instant Play Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/no-download-games/instant-play",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": noDownloadGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/no-download-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">No Download Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Instant Play</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Instant Play Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Zero wait time. Maximum fun. Click and play immediately.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-green-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>What are Instant Play Games?</h3>
      <p>Instant play games are designed for speed. They load in seconds and require absolutely no installation or disk space. Whether you have 5 minutes or an hour, these games are ready when you are.</p>
      <ul>
        <li><strong>Click & Play:</strong> No registration or setup required.</li>
        <li><strong>Save Storage:</strong> Keep your device clean and fast.</li>
        <li><strong>Play Anywhere:</strong> Access your favorite games from any computer.</li>
      </ul>
    </div>

    <GameGrid games={noDownloadGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>The Ultimate Instant Play Experience</h2>
      <p>
        Time is precious, and we believe you shouldn't waste it watching progress bars. Our Instant Play games are curated for immediate enjoyment.
        Leveraging modern web streaming and efficient asset loading, these games start almost as soon as you click the link.
      </p>
      
      <h3>Perfect for Quick Breaks</h3>
      <p>
        Got five minutes before a meeting? Waiting for a render to finish? Instant play games are the perfect way to fill those small gaps in your day with something fun and engaging.
      </p>
      <ul>
        <li><strong>Low Latency:</strong> Optimized for quick response times.</li>
        <li><strong>Browser Caching:</strong> Frequently played games load even faster.</li>
        <li><strong>No Commitment:</strong> Play for a few minutes and close the tab without guilt.</li>
      </ul>
    </div>
  </section>
</Layout>
