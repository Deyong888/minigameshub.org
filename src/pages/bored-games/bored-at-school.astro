---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { boredAtSchoolGames } from '~/data/games';

const metadata = {
  title: 'Bored at School Games - Unblocked Games for Students',
  description: 'Play unblocked games at school. Fun, educational, and safe for work/school environments.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Bored at School Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/bored-games/bored-at-school",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": boredAtSchoolGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/bored-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">Bored Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Bored at School</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-8 md:mb-12 font-heading text-center">
      Bored at School Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      School-friendly games that work on chromebooks and school networks.
    </p>

    <GameGrid games={boredAtSchoolGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Unblocked Games for Students</h2>
      <p>
        Study breaks are essential for keeping your mind fresh. Our Bored at School collection features safe, unblocked games that are perfect for playing during recess or free periods.
        These games are lightweight and work great on Chromebooks and school networks where other sites might be restricted.
      </p>
      
      <h3>Educational and Fun</h3>
      <p>
        Not all games are mind-numbing! We have a selection of puzzle and logic games that can actually help sharpen your critical thinking skills.
      </p>
      <ul>
        <li><strong>Brain Training:</strong> Logic puzzles and math games.</li>
        <li><strong>Skill Building:</strong> Typing games and reflex challenges.</li>
        <li><strong>Creativity:</strong> Drawing and building games to unleash your imagination.</li>
      </ul>
      
      <h3>Safe for School</h3>
      <p>
        All games in this category are vetted to be appropriate for all ages, with no graphic violence or inappropriate themes.
      </p>
    </div>
  </section>
</Layout>
