---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'Offline Capable Games - Play Without Internet | MiniGamesHub',
  description: 'Browser games that work even when your internet connection is spotty. Once loaded, these HTML5 games can run offline.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Offline Capable Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/html5-games/offline-capable",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/html5-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">HTML5 Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Offline Capable</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Offline Capable Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Keep playing even when the Wi-Fi goes down.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>No Internet? No Problem.</h3>
      <p>Thanks to modern Service Worker technology and efficient caching, many HTML5 games can continue to run even if you lose your internet connection after loading them.</p>
      <ul>
        <li><strong>Travel Friendly:</strong> Perfect for flights or road trips with unstable internet.</li>
        <li><strong>Data Saver:</strong> Play without constantly using your mobile data plan.</li>
        <li><strong>Resilient:</strong> Don't let lag spikes ruin your high score run.</li>
      </ul>
    </div>

    <GameGrid games={html5Games} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Uninterrupted Fun: Games That Don't Need Constant WiFi</h2>
      <p>
        Internet connections can be unreliable, but your fun shouldn't be. Our offline-capable games utilize advanced web technologies like Service Workers and local caching to ensure the game keeps running even if you drop offline.
        Once the game assets are loaded for the first time, they are stored on your device, allowing for instant reloads and offline play.
      </p>
      
      <h3>Perfect Scenarios for Offline Gaming</h3>
      <ul>
        <li><strong>Commuting:</strong> Play on the subway or bus where signals are weak.</li>
        <li><strong>Air Travel:</strong> Enjoy games during flights without paying for expensive Wi-Fi.</li>
        <li><strong>Data Saving:</strong> great for users with limited data plans.</li>
      </ul>
      
      <h3>How to Play Offline</h3>
      <p>
        Simply load the game once while you have a connection. Do not clear your browser cache for that site. Next time you visit, the game should load instantly from your device's memory.
      </p>
    </div>
  </section>
</Layout>
