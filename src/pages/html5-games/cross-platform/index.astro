---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'Cross Platform Games - Play on PC, Tablet & Mobile | MiniGamesHub',
  description: 'Play games that work on every device. Start on your PC, continue on your mobile. Seamless cross-platform gaming experience.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Cross Platform Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/html5-games/cross-platform",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="text-sm text-gray-500 mb-4 text-center">
      <a href="/" class="hover:text-primary">Home</a> &gt; 
      <a href="/html5-games" class="hover:text-primary">HTML5 Games</a> &gt; 
      <span class="font-bold text-gray-700 dark:text-gray-300">Cross Platform</span>
    </div>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Cross Platform Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      One game, every device. Play where you want.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>Play Anywhere</h3>
      <p>Why limit yourself to one device? Our cross-platform games are built with responsive HTML5 technology that adapts to your screen size and input method automatically.</p>
      <ul>
        <li><strong>Universal Compatibility:</strong> Windows, macOS, iOS, Android, Linux.</li>
        <li><strong>Seamless Experience:</strong> The same great game, no matter how you play.</li>
        <li><strong>Browser Based:</strong> No need to install separate apps for different devices.</li>
      </ul>
    </div>

    <GameGrid games={html5Games} />
  </section>
</Layout>
