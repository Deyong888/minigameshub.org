---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'Mobile Friendly Games - Play on iPhone & Android | MiniGamesHub',
  description: 'Play free mobile-friendly games optimized for smartphones and tablets. No app installation required, works in your mobile browser.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Mobile Friendly Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/html5-games/mobile-friendly",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/html5-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">HTML5 Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Mobile Friendly</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Mobile Friendly Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Games designed for your phone's touchscreen.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>Gaming on the Go</h3>
      <p>Take your gaming anywhere with our collection of mobile-optimized titles. These games are designed to work perfectly on small screens with touch controls.</p>
      <ul>
        <li><strong>Responsive Design:</strong> Fits any screen size, from iPhone to iPad Pro.</li>
        <li><strong>Touch Controls:</strong> Intuitive tap and swipe mechanics.</li>
        <li><strong>No App Store:</strong> Play instantly in Safari or Chrome.</li>
      </ul>
    </div>

    <GameGrid games={html5Games} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>The Best Browser Games for Android and iOS</h2>
      <p>
        Gone are the days when mobile gaming meant downloading huge apps that clutter your storage. Our mobile-friendly browser games offer app-quality experiences directly in Safari or Chrome.
        Optimized specifically for touchscreens, these games feature larger buttons, swipe gestures, and simplified interfaces.
      </p>
      
      <h3>Why Choose Browser Games on Mobile?</h3>
      <ul>
        <li><strong>Save Storage Space:</strong> No need to download 1GB+ files for a simple puzzle game.</li>
        <li><strong>Instant Updates:</strong> You always play the latest version without waiting for app store updates.</li>
        <li><strong>Battery Efficient:</strong> Many HTML5 games are lighter on your battery than heavy 3D native apps.</li>
      </ul>
      
      <h3>Portrait vs. Landscape</h3>
      <p>
        We offer games that support both orientations. Play one-handed in portrait mode while commuting, or flip your phone to landscape for a more immersive view.
      </p>
    </div>
  </section>
</Layout>
