---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'Mobile Friendly Games - Play on iPhone & Android | MiniGamesHub',
  description: 'Play free mobile-friendly games optimized for smartphones and tablets. No app installation required, works in your mobile browser.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Mobile Friendly Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/html5-games/mobile-friendly",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="text-sm text-gray-500 mb-4 text-center">
      <a href="/" class="hover:text-primary">Home</a> &gt; 
      <a href="/html5-games" class="hover:text-primary">HTML5 Games</a> &gt; 
      <span class="font-bold text-gray-700 dark:text-gray-300">Mobile Friendly</span>
    </div>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Mobile Friendly Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Games designed for your phone's touchscreen.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>Gaming on the Go</h3>
      <p>Take your gaming anywhere with our collection of mobile-optimized titles. These games are designed to work perfectly on small screens with touch controls.</p>
      <ul>
        <li><strong>Responsive Design:</strong> Fits any screen size, from iPhone to iPad Pro.</li>
        <li><strong>Touch Controls:</strong> Intuitive tap and swipe mechanics.</li>
        <li><strong>No App Store:</strong> Play instantly in Safari or Chrome.</li>
      </ul>
    </div>

    <GameGrid games={html5Games} />
  </section>
</Layout>
