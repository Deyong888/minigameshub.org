---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { relaxCasualGames } from '~/data/games';

const metadata = {
  title: 'Casual Relax Games - Low Pressure Fun',
  description: 'Enjoy low-pressure gaming with our casual relax games. No timers, no high scores, just fun.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Casual Relax Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/relax-games/casual",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": relaxCasualGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/relax-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary md:ml-2 dark:text-gray-400 dark:hover:text-white">Relax Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Casual</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Casual Relax Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Laid-back games for pure enjoyment.
    </p>
    <GameGrid games={relaxCasualGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Casual Gaming for a Lazy Afternoon</h2>
      <p>
        Casual games are the comfort food of the gaming world. They are familiar, easy to digest, and always satisfying. Our Casual Relax collection focuses on low-pressure fun where the only goal is to have a good time.
        No complex strategies to memorize, no punishing difficulty curves—just pure entertainment.
      </p>
      
      <h3>Why Casual Games Rule</h3>
      <ul>
        <li><strong>Low Commitment:</strong> Start and stop whenever you want without losing progress.</li>
        <li><strong>Intuitive:</strong> You already know how to play most of these games instantly.</li>
        <li><strong>Family Friendly:</strong> Great for players of all ages, from kids to grandparents.</li>
      </ul>
      
      <h3>Popular Casual Genres</h3>
      <p>
        From digital card games like Solitaire to simple building games and dress-up sims, there is a casual game for every taste and mood.
      </p>
    </div>
  </section>
</Layout>
