---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { relaxStressReliefGames } from '~/data/games';

const metadata = {
  title: 'Stress Relief Games - Pop, Smash & Relax',
  description: 'Relieve stress with satisfying games. Pop bubbles, smash items, and let go of tension.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Stress Relief Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/relax-games/stress-relief",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": relaxStressReliefGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/relax-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary md:ml-2 dark:text-gray-400 dark:hover:text-white">Relax Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Stress Relief</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Stress Relief Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Satisfying games designed to melt away stress.
    </p>
    <GameGrid games={relaxStressReliefGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Pop, Smash, and Destroy Your Stress</h2>
      <p>
        Sometimes you don't want to be calm; you want to smash something. Our Stress Relief games provide a safe, digital outlet for your frustration.
        Pop endless sheets of bubble wrap, destroy virtual objects, or engage in chaotic ragdoll physics. It's cathartic, fun, and cheaper than therapy!
      </p>
      
      <h3>The Science of Digital Fidgeting</h3>
      <p>
        Just like fidget spinners, these games give your hands something to do, which can help channel nervous energy and improve focus.
      </p>
      <ul>
        <li><strong>Instant Gratification:</strong> clear feedback loops with satisfying sounds and visuals.</li>
        <li><strong>Control:</strong> You are the master of your environment, giving you a sense of agency.</li>
        <li><strong>Safe Outlet:</strong> Release tension without any real-world consequences.</li>
      </ul>
    </div>
  </section>
</Layout>
