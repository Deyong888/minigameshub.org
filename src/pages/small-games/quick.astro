---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { smallQuickGames } from '~/data/games';

const metadata = {
  title: 'Quick Small Games - Instant Play',
  description: 'Jump into action with quick small games. No waiting, just playing.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Quick Small Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/small-games/quick",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": smallQuickGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/small-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">Small Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Quick</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-8 md:mb-12 font-heading text-center">
      Quick Small Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Games designed for quick sessions.
    </p>
    <GameGrid games={smallQuickGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Speedy Gaming for Busy Lives</h2>
      <p>
        Life moves fast, and sometimes you only have a moment to spare. Our Quick Games collection is built for speed.
        From the moment you click "Play" to the moment you finish a round, everything is streamlined for maximum efficiency.
      </p>
      
      <h3>Why Play Quick Games?</h3>
      <ul>
        <li><strong>Instant Start:</strong> No intro movies or long loading screens.</li>
        <li><strong>Short Loops:</strong> Gameplay cycles that last 30-60 seconds.</li>
        <li><strong>High Intensity:</strong> Often focused on reaction time and high scores.</li>
      </ul>
      
      <h3>The "One More Try" Effect</h3>
      <p>
        These games are masters of the "just one more go" feeling. Their short duration makes them addictive and perfect for filling dead time during your day.
      </p>
    </div>
  </section>
</Layout>
