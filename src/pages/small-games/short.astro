---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { smallShortGames } from '~/data/games';

const metadata = {
  title: 'Short Small Games - Bite-sized Fun',
  description: 'Short games for when you only have a few minutes. Simple, fun, and fast.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Short Small Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/small-games/short",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": smallShortGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/small-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">Small Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Short</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-8 md:mb-12 font-heading text-center">
      Short Small Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Bite-sized games for the shortest breaks.
    </p>
    <GameGrid games={smallShortGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Micro-Gaming: Fun in Under 5 Minutes</h2>
      <p>
        Welcome to the world of micro-gaming. Our Short Games are specifically curated for those times when you need a quick distraction but can't commit to a longer session.
        Perfect for waiting in line, brewing coffee, or commercial breaks.
      </p>
      
      <h3>Features of Short Games</h3>
      <ul>
        <li><strong>Commuter Friendly:</strong> Play a full round between bus stops.</li>
        <li><strong>Simple Goals:</strong> Clear, achievable objectives that don't require saving progress.</li>
        <li><strong>High Replay Value:</strong> Randomized elements keep the game fresh every time you play.</li>
      </ul>
      
      <h3>Quality Over Quantity</h3>
      <p>
        Just because a game is short doesn't mean it lacks depth. Many of these titles offer clever mechanics and polished visuals packed into a bite-sized package.
      </p>
    </div>
  </section>
</Layout>
