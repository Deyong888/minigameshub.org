---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { miniRelaxGames } from '~/data/games';

const metadata = {
  title: 'Relax Mini Games - Chill & Play',
  description: 'Unwind with our relaxing mini games. Stress-free gaming for a quick break.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Relax Mini Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/mini-games/relax",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": miniRelaxGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/mini-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary md:ml-2 dark:text-gray-400 dark:hover:text-white">Mini Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Relax</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Relax Mini Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Calming games to help you de-stress and relax.
    </p>
    <GameGrid games={miniRelaxGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Your Stress-Free Gaming Zone</h2>
      <p>
        Take a deep breath and unwind with our relaxing mini-games. In this section, you won't find ticking clocks, game-over screens, or intense combat.
        Instead, we offer soothing experiences designed to help you de-stress and find a moment of calm in your chaotic day.
      </p>
      
      <h3>Features of Relaxing Games</h3>
      <ul>
        <li><strong>Calming Atmosphere:</strong> Soothing background music and gentle sound effects.</li>
        <li><strong>No Pressure:</strong> Play at your own pace without fear of losing.</li>
        <li><strong>Satisfying Mechanics:</strong> Enjoy activities like sorting, coloring, or simple repetitive tasks that trigger ASMR.</li>
      </ul>
      
      <h3>When to Play</h3>
      <p>
        These games are perfect for winding down before bed, taking a mental health break at work, or simply when you want to enjoy beautiful visuals without the adrenaline rush.
      </p>
    </div>
  </section>
</Layout>
