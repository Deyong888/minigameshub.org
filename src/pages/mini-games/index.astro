---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { miniGames } from '~/data/games';

const metadata = {
  title: 'Mini Games - Quick Fun Browser Games',
  description: 'Instant fun with our collection of mini games. No install, no login, just play.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Mini Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/mini-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": miniGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Mini Games</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Mini Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Bite-sized entertainment for quick breaks.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/mini-games/arcade" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Arcade</a>
      <a href="/mini-games/puzzle" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Puzzle</a>
      <a href="/mini-games/action" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Action</a>
      <a href="/mini-games/relax" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Relax</a>
    </div>

    <GameGrid games={miniGames} />

    <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-700">
      <h2 class="text-2xl font-bold text-center mb-8">Explore Mini Game Categories</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/mini-games/arcade" class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg hover:shadow-lg transition text-center group">
          <h3 class="font-bold text-lg mb-2 group-hover:text-primary">Arcade Mini</h3>
          <p class="text-sm text-gray-500">Classic arcade fun in bite-sized chunks.</p>
        </a>
        <a href="/mini-games/puzzle" class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg hover:shadow-lg transition text-center group">
          <h3 class="font-bold text-lg mb-2 group-hover:text-primary">Puzzle Mini</h3>
          <p class="text-sm text-gray-500">Quick brain teasers to test your logic.</p>
        </a>
        <a href="/mini-games/action" class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg hover:shadow-lg transition text-center group">
          <h3 class="font-bold text-lg mb-2 group-hover:text-primary">Action Mini</h3>
          <p class="text-sm text-gray-500">Fast-paced excitement for short breaks.</p>
        </a>
        <a href="/mini-games/relax" class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg hover:shadow-lg transition text-center group">
          <h3 class="font-bold text-lg mb-2 group-hover:text-primary">Relax Mini</h3>
          <p class="text-sm text-gray-500">Chill out with stress-free mini games.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
