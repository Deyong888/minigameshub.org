---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { miniPuzzleGames } from '~/data/games';

const metadata = {
  title: 'Puzzle Mini Games - Brain Teasers & Logic',
  description: 'Challenge your mind with our collection of puzzle mini games. Sudoku, 2048, Match-3 and more.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Puzzle Mini Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/mini-games/puzzle",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": miniPuzzleGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/mini-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary md:ml-2 dark:text-gray-400 dark:hover:text-white">Mini Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Puzzle</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Puzzle Mini Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Brain teasers, logic puzzles, and mind-bending challenges.
    </p>
    <GameGrid games={miniPuzzleGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Exercise Your Brain with Logic Puzzles</h2>
      <p>
        Sharpen your mind with our diverse selection of puzzle mini-games. From classic Sudoku and crosswords to modern physics-based challenges and match-3 games, there's a puzzle for every type of thinker.
        These games are not just fun; they are a great workout for your brain, helping to improve problem-solving skills and concentration.
      </p>
      
      <h3>Types of Puzzle Games We Offer</h3>
      <ul>
        <li><strong>Logic Puzzles:</strong> Test your deductive reasoning with grid-based challenges.</li>
        <li><strong>Match-3:</strong> Relaxing and colorful games where you connect items to clear the board.</li>
        <li><strong>Physics Games:</strong> Use gravity and mechanics to solve creative problems.</li>
        <li><strong>Word Games:</strong> Expand your vocabulary with word searches and anagrams.</li>
      </ul>
      
      <h3>Benefits of Puzzle Gaming</h3>
      <p>
        Taking a break to solve a puzzle can actually boost your productivity. It engages different parts of your brain and can provide a refreshing mental reset during a busy day.
      </p>
    </div>
  </section>
</Layout>
