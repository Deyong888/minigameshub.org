---
import Layout from '~/layouts/PageLayout.astro';
import { getLangFromUrl, useTranslations } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const metadata = {
  title: t('search.title'),
  description: t('search.description'),
};

const placeholder = t('search.placeholder');
const zeroResults = t('search.noResults');
---

<Layout metadata={metadata}>
  <section class="px-6 py-12 sm:px-6 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <div class="mb-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
        {t('search.title')}
      </h1>
      <p class="max-w-3xl mx-auto text-xl text-muted dark:text-slate-400">
        {t('search.description')}
      </p>
    </div>

    <div id="search" class="w-full min-h-[500px]"></div>
  </section>
</Layout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script is:inline define:vars={{ placeholder, zeroResults }}>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({ 
        element: "#search", 
        showSubResults: true,
        showImages: true,
        translations: {
            placeholder: placeholder,
            zero_results: zeroResults
        }
    });
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #3b82f6;
    --pagefind-ui-text: #1f2937;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: #f3f4f6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-image-border-radius: 0.5rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }

  .dark {
    --pagefind-ui-primary: #60a5fa;
    --pagefind-ui-text: #f9fafb;
    --pagefind-ui-background: #1f2937;
    --pagefind-ui-border: #374151;
    --pagefind-ui-tag: #374151;
  }
  
  .pagefind-ui__result-thumb {
      object-fit: cover;
      background-color: #1f2937;
  }
</style>