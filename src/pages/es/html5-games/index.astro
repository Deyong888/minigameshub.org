---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'Juegos HTML5 - Juega Juegos Web Modernos Gratis',
  description: 'Disfruta de los últimos juegos HTML5 jugables en cualquier dispositivo. Juegos compatibles con móviles, multiplataforma y con capacidad offline que funcionan fluidamente en tu navegador.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos HTML5",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/html5-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/es/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Juegos HTML5</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos HTML5
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Juegos modernos, rápidos y hermosos que funcionan en todas partes.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/es/html5-games/mobile-friendly" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Compatible con Móvil</a>
      <a href="/es/html5-games/cross-platform" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Multiplataforma</a>
      <a href="/es/html5-games/offline-capable" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Modo Offline</a>
    </div>

    <GameGrid games={html5Games} />

    <div class="mt-16">
      <h2 class="text-2xl font-bold mb-8 text-center">Explora Categorías de Juegos HTML5</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/es/html5-games/mobile-friendly" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">Compatible con Móvil</h3>
          <p class="text-gray-600 dark:text-gray-400">Juegos optimizados para pantallas táctiles y teléfonos.</p>
        </a>
        <a href="/es/html5-games/cross-platform" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">Multiplataforma</h3>
          <p class="text-gray-600 dark:text-gray-400">Juega en PC, tablet o móvil sin perder el progreso.</p>
        </a>
        <a href="/es/html5-games/offline-capable" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">Modo Offline</h3>
          <p class="text-gray-600 dark:text-gray-400">Juegos que funcionan incluso sin conexión a Internet.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
