---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'Juegos HTML5 - Juega Juegos Web Modernos Gratis',
  description: 'Disfruta de los últimos juegos HTML5 jugables en cualquier dispositivo. Juegos compatibles con móviles, multiplataforma y con capacidad offline que funcionan fluidamente en tu navegador.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos HTML5",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/html5-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/es/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos HTML5
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Juegos modernos, rápidos y hermosos que funcionan en todas partes.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/es/html5-games/mobile-friendly" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Compatible con Móvil</a>
      <a href="/es/html5-games/cross-platform" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Multiplataforma</a>
      <a href="/es/html5-games/offline-capable" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Modo Offline</a>
    </div>

    <GameGrid games={html5Games} />
  </section>
</Layout>
