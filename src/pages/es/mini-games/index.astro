---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { miniGames } from '~/data/games';

const metadata = {
  title: 'Minijuegos - Juegos de Navegador Rápidos y Divertidos',
  description: 'Diversión instantánea con nuestra colección de minijuegos. Sin instalación, sin registro, solo juega.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Minijuegos",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/mini-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": miniGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/es/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Minijuegos</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Minijuegos
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Entretenimiento rápido para descansos cortos.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/es/mini-games/arcade" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Arcade</a>
      <a href="/es/mini-games/puzzle" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Puzle</a>
      <a href="/es/mini-games/action" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Acción</a>
      <a href="/es/mini-games/relax" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Relax</a>
    </div>

    <GameGrid games={miniGames} />

    <div class="mt-16">
      <h2 class="text-2xl font-bold mb-8 text-center">Explora Categorías de Minijuegos</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/es/mini-games/action" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-300 group-hover:bg-red-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Acción</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Adrenalina y combate rápido.</p>
        </a>

        <a href="/es/mini-games/arcade" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-yellow-100 dark:bg-yellow-900 text-yellow-600 dark:text-yellow-300 group-hover:bg-yellow-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Arcade</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Clásicos rápidos y puntuaciones altas.</p>
        </a>

        <a href="/es/mini-games/puzzle" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 group-hover:bg-blue-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Puzle</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Desafíos mentales rápidos.</p>
        </a>

        <a href="/es/mini-games/relax" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-300 group-hover:bg-green-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Relax</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Juegos tranquilos para desestresarse.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>

