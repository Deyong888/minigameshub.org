---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { noDownloadGames } from '~/data/games';

const metadata = {
  title: 'Juegos Sin Instalación - No Requiere Configuración | MiniGamesHub',
  description: 'Disfruta de juegos de alta calidad sin instalar nada en tu computadora. Los juegos sin instalación mantienen tu dispositivo limpio y seguro.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos Sin Instalación",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/no-download-games/zero-install",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": noDownloadGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/es/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="text-sm text-gray-500 mb-4 text-center">
      <a href="/es/" class="hover:text-primary">Inicio</a> &gt; 
      <a href="/es/no-download-games" class="hover:text-primary">Sin Descarga</a> &gt; 
      <span class="font-bold text-gray-700 dark:text-gray-300">Sin Instalación</span>
    </div>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos Sin Instalación
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Mantén tu dispositivo limpio. Solo juega.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>¿Por qué elegir Sin Instalación?</h3>
      <p>Instalar juegos puede desordenar tu disco duro y plantear riesgos de seguridad. Los juegos sin instalación se ejecutan completamente en el sandbox de tu navegador, manteniendo tu computadora segura y tu almacenamiento libre.</p>
      <ul>
        <li><strong>Seguridad:</strong> No hay archivos ejecutables para ejecutar en tu sistema.</li>
        <li><strong>Almacenamiento:</strong> Ahorra gigabytes de espacio en tu disco duro.</li>
        <li><strong>Limpio:</strong> Sin archivos sobrantes o entradas de registro cuando terminas.</li>
      </ul>
    </div>

    <GameGrid games={noDownloadGames} />
  </section>
</Layout>
