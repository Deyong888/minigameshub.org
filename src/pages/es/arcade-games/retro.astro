---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { arcadeRetroGames } from '~/data/games';

const metadata = {
  title: 'Juegos Arcade Retro - Pixel Perfect',
  description: 'Pixel art y chiptunes. Sumérgete en la bondad del arcade retro.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos Arcade Retro",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/arcade-games/retro",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": arcadeRetroGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li class="inline-flex items-center">
          <a href="/es/arcade-games" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            Juegos Arcade
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Retro</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos Arcade Retro
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Juegos nostálgicos con arte pixel-perfect.
    </p>
    <GameGrid games={arcadeRetroGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Nostalgia Pixelada</h2>
      <p>
        Los juegos retro capturan la estética y el encanto de los años 80 y 90. Con gráficos pixel art y bandas sonoras chiptune, estos juegos son un homenaje a la era dorada de los videojuegos.
        Perfectos para aquellos que aprecian el estilo artístico clásico y la jugabilidad directa.
      </p>
      <h3>Estética Retro</h3>
      <p>
        El estilo retro es más que solo gráficos antiguos; es una forma de arte.
      </p>
      <ul>
        <li><strong>Pixel Art:</strong> Estilo visual auténtico y encantador que nunca pasa de moda.</li>
        <li><strong>Chiptunes:</strong> Música electrónica pegadiza al estilo de 8 y 16 bits.</li>
        <li><strong>Jugabilidad Clásica:</strong> Controles sencillos y diversión directa sin complicaciones.</li>
      </ul>
    </div>
  </section>
</Layout>
