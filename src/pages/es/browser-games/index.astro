---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { browserGames } from '~/data/games';

const metadata = {
  title: 'Juegos de Navegador - Juega Gratis Online Sin Descargas',
  description: 'Juega los mejores juegos de navegador online al instante. Sin descargas ni instalaciones. Disfruta de miles de juegos HTML5 y WebGL gratis directamente en tu navegador.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos de Navegador",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/browser-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": browserGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/es/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description, // Note: Description might be in English, but acceptable for now
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Juegos de Navegador</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos de Navegador
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Juega miles de juegos gratis directamente en tu navegador. Sin descargas, sin complicaciones.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/es/browser-games/html5" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">HTML5</a>
      <a href="/es/browser-games/webgl" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">WebGL</a>
      <a href="/es/browser-games/flash-alternative" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Alternativa Flash</a>
    </div>

    <GameGrid games={browserGames} />

    <div class="mt-16">
      <h2 class="text-2xl font-bold mb-8 text-center">Explora Categorías de Juegos de Navegador</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/es/browser-games/html5" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">HTML5</h3>
          <p class="text-gray-600 dark:text-gray-400">Juegos modernos compatibles con todos los dispositivos.</p>
        </a>
        <a href="/es/browser-games/webgl" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">WebGL</h3>
          <p class="text-gray-600 dark:text-gray-400">Gráficos 3D impresionantes en tu navegador.</p>
        </a>
        <a href="/es/browser-games/flash-alternative" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">Alternativa Flash</h3>
          <p class="text-gray-600 dark:text-gray-400">Clásicos preservados para la era moderna.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
