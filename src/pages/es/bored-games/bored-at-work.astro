---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { boredAtWorkGames } from '~/data/games';

const metadata = {
  title: 'Juegos para Jugar en el Trabajo - Juega en Secreto en la Oficina',
  description: 'La mejor colección de juegos de navegador para jugar cuando estás aburrido en el trabajo. ¡Sin descarga, con tecla de jefe incluida!',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos para Jugar en el Trabajo",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/bored-games/bored-at-work",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": boredAtWorkGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li class="inline-flex items-center">
          <a href="/es/bored-games/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            Juegos para el Aburrimiento
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">En el Trabajo</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-8 md:mb-12 font-heading text-center">
      Juegos para Jugar en el Trabajo
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Minijuegos discretos perfectos para descansos en la oficina. Rápidos de jugar, fáciles de ocultar.
    </p>

    <GameGrid games={boredAtWorkGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Diversión Discreta para la Oficina</h2>
      <p>
        Todos necesitamos un descanso mental en el trabajo para recargar energías. Nuestra colección de juegos para la oficina está diseñada para ser discreta, silenciosa y rápida de cerrar si el jefe se acerca.
        Aumenta tu productividad tomando breves descansos estratégicos con estos juegos de navegador.
      </p>
      <h3>Características Amigables para el Trabajo</h3>
      <ul>
        <li><strong>Tecla de Jefe:</strong> Cierra u oculta el juego instantáneamente con un atajo de teclado.</li>
        <li><strong>Silenciosos por Defecto:</strong> Muchos juegos comienzan sin sonido para evitar situaciones incómodas.</li>
        <li><strong>Partidas Rápidas:</strong> Perfectos para descansos de 5 minutos entre tareas.</li>
      </ul>
    </div>
  </section>
</Layout>

