---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { boredAtWorkGames, boredAtSchoolGames, waitingInLineGames } from '~/data/games';

const games = [...boredAtWorkGames.slice(0, 12), ...boredAtSchoolGames.slice(0, 12), ...waitingInLineGames.slice(0, 12)];

const metadata = {
  title: 'Juegos para el Aburrimiento - Juega Cuando Estés Aburrido',
  description: 'La mejor colección de juegos para jugar cuando estás aburrido. En el trabajo, en la escuela o esperando en la fila.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos para el Aburrimiento",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/bored-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Juegos para el Aburrimiento</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos para el Aburrimiento
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Cura tu aburrimiento con nuestras colecciones de juegos seleccionadas.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/es/bored-games/bored-at-work" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Aburrido en el Trabajo</a>
      <a href="/es/bored-games/bored-at-school" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Aburrido en la Escuela</a>
      <a href="/es/bored-games/waiting-in-line" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Esperando en Fila</a>
    </div>

    <GameGrid games={games} />

    <div class="mt-16">
      <h2 class="text-2xl font-bold mb-8 text-center">Explora Categorías para el Aburrimiento</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/es/bored-games/bored-at-work" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 group-hover:bg-blue-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">En el Trabajo</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Juegos discretos para esos momentos libres en la oficina.</p>
        </a>

        <a href="/es/bored-games/bored-at-school" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-purple-100 dark:bg-purple-900 text-purple-600 dark:text-purple-300 group-hover:bg-purple-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path d="M12 14l9-5-9-5-9 5 9 5z" />
                <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">En la Escuela</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Juegos desbloqueados y educativos para estudiantes.</p>
        </a>

        <a href="/es/bored-games/waiting-in-line" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-300 group-hover:bg-green-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Esperando</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Juegos rápidos para matar el tiempo en filas.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>

