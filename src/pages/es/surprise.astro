---
import Layout from '~/layouts/PageLayout.astro';
import { allGames } from '~/data/games';

const title = "¡Sorpréndeme!";
const pool = allGames.sort(() => 0.5 - Math.random()).slice(0, 30);
---

<Layout metadata={{ title }}>
  <Fragment slot="header"></Fragment>
  <Fragment slot="footer"></Fragment>
  <Fragment slot="announcement"></Fragment>

  <section class="flex items-center justify-center min-h-screen bg-slate-900 text-white relative overflow-hidden">
    <!-- Dynamic Background -->
    <div class="absolute inset-0 z-0 opacity-20 grid grid-cols-3 md:grid-cols-6 gap-2 transform -skew-y-6 scale-110 animate-pulse">
      {pool.map((g) => (
        <div class="aspect-square bg-cover bg-center rounded-lg" style={`background-image: url(${g.thumbnail})`}></div>
      ))}
    </div>
    
    <div class="z-10 relative flex flex-col items-center max-w-lg w-full mx-4">
      <!-- Slot Machine Card -->
      <div class="bg-slate-800/80 backdrop-blur-xl p-8 rounded-3xl border border-white/10 shadow-2xl w-full flex flex-col items-center transform transition-all hover:scale-105 duration-500">
        
        <!-- Game Display -->
        <div class="relative w-64 h-64 mb-8 bg-black rounded-2xl overflow-hidden shadow-[0_0_30px_rgba(59,130,246,0.5)] border-4 border-slate-700">
           <img id="slotImage" src={pool[0]?.thumbnail} class="w-full h-full object-cover transition-transform duration-100" alt="Juego Aleatorio" />
           <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent flex items-end justify-center pb-4">
             <span id="slotTitle" class="text-white font-bold text-xl text-center px-4 truncate w-full drop-shadow-md">...</span>
           </div>
        </div>
        
        <h1 id="statusText" class="text-3xl md:text-4xl font-bold mb-6 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500 animate-pulse">
          Girando...
        </h1>

        <!-- Progress Bar -->
        <div class="w-full bg-slate-700 rounded-full h-3 overflow-hidden">
          <div id="progressBar" class="bg-gradient-to-r from-blue-500 to-purple-600 h-full rounded-full transition-all duration-100 ease-out" style="width: 0%"></div>
        </div>
      </div>
      
      <p class="mt-8 text-slate-400 font-medium">Seleccionando un juego aleatorio para ti...</p>
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ pool }}>
  const duration = 2500;
  const interval = 100;
  const steps = duration / interval;
  let currentStep = 0;
  
  const imgEl = document.getElementById('slotImage');
  const titleEl = document.getElementById('slotTitle');
  const progressEl = document.getElementById('progressBar');
  const statusEl = document.getElementById('statusText');

  const finalGameIndex = Math.floor(Math.random() * pool.length);
  const finalGame = pool[finalGameIndex];

  const shuffle = setInterval(() => {
    currentStep++;
    const progress = (currentStep / steps) * 100;
    
    const randomIdx = Math.floor(Math.random() * pool.length);
    const game = pool[randomIdx];
    
    if (imgEl) imgEl.src = game.thumbnail;
    if (titleEl) titleEl.textContent = game.title;
    if (progressEl) progressEl.style.width = `${progress}%`;

    if (currentStep >= steps) {
      clearInterval(shuffle);
      finish();
    }
  }, interval);

  function finish() {
    if (imgEl) imgEl.src = finalGame.thumbnail;
    if (titleEl) titleEl.textContent = finalGame.title;
    if (statusEl) {
      statusEl.textContent = "¡A jugar!";
      statusEl.classList.remove('animate-pulse');
      statusEl.classList.add('scale-110');
    }
    
    setTimeout(() => {
      // Ensure URL format matches [id]-[slug] route
      window.location.href = `/es/game/${finalGame.id}-${finalGame.slug}`;
    }, 500);
  }
</script>
