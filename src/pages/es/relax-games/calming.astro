---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { relaxCalmingGames } from '~/data/games';

const metadata = {
  title: 'Juegos Calmantes - Zen y Paz',
  description: 'Encuentra tu zen con juegos calmantes. Rompecabezas suaves, visuales hermosos y jugabilidad relajante.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos Calmantes",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/relax-games/calming",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": relaxCalmingGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li class="inline-flex items-center">
          <a href="/es/relax-games" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            Juegos de Relajación
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Calmantes</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos Calmantes
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Experiencias pacíficas para calmar tu mente.
    </p>
    <GameGrid games={relaxCalmingGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Experiencias Zen Digitales</h2>
      <p>
        Sumérgete en un estado de flujo con nuestra colección de juegos calmantes. A diferencia de los juegos tradicionales que exigen reflejos rápidos, estos títulos invitan a la contemplación y la paciencia. La estética visual suave y las bandas sonoras ambientales crean una atmósfera perfecta para la relajación.
      </p>
      <h3>Características de los juegos Zen</h3>
      <ul>
        <li><strong>Estética Minimalista:</strong> Diseños limpios que no sobrecargan los sentidos.</li>
        <li><strong>Música Ambiental:</strong> Paisajes sonoros diseñados para reducir la frecuencia cardíaca.</li>
        <li><strong>Progreso Suave:</strong> Avanza a tu propio ritmo sin miedo al fracaso.</li>
      </ul>
    </div>
  </section>
</Layout>
