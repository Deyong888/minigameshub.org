---
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import GamePlayer from '~/components/game/GamePlayer.astro';
import { getUniqueGames, getRelatedGames } from '~/data/games';
import { getLangFromUrl, useTranslations } from '~/utils/i18n';
import type { Game } from '~/types/game';

export async function getStaticPaths() {
  const games = getUniqueGames();
  
  return games.map((game) => ({
    params: { id: game.id.toString(), slug: game.slug },
    props: { game, relatedGames: getRelatedGames(game, 12) },
  }));
}

export interface Props {
  game: Game;
  relatedGames: Game[];
}

const { game, relatedGames } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getTranslatedCategory = (cat: string) => {
    const key = `cat.${cat.toLowerCase()}`;
    const translated = (t as any)(key);
    return translated || cat.charAt(0).toUpperCase() + cat.slice(1);
};

const translatedCategory = getTranslatedCategory(game.category);

const metadata = {
  title: `Juega ${game.title} - Juego en línea gratis | MiniGamesHub.org`,
  description: `Juega ${game.title} en línea gratis en MiniGamesHub.org. No requiere descarga. ${game.description}`,
  openGraph: {
    type: 'video.other',
    images: [
        {
            url: game.thumbnail,
            width: 1200,
            height: 630,
            alt: game.title
        }
    ]
  },
};

const playerLabels = {
    loading: 'Cargando',
    bossKey: 'Modo Jefe',
    mute: 'Silenciar',
    unmute: 'Activar Sonido',
    fullscreen: 'Pantalla Completa',
    bossKeyHint: 'Presiona ESC para modo Jefe',
    returnToGame: 'Presiona ESC para volver al juego...'
};
---

<Layout metadata={metadata}>
  <!-- Game Player Section -->
  <WidgetWrapper id="game-player" containerClass="max-w-7xl mx-auto py-6" bg="<div class='absolute inset-0 bg-blue-50 dark:bg-transparent'></div>">
    
    <!-- Breadcrumbs (SVG) -->
    <nav class="flex mb-4" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            {t('nav.home')}
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href={`/es/category/${game.category.toLowerCase().replace(/\s+/g, '-')}`} class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">{translatedCategory}</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">{game.title}</span>
          </div>
        </li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Main Game Area (2/3 width) -->
      <div class="lg:col-span-2">
        <GamePlayer game={game} labels={playerLabels} />

        <!-- Game Controls / Info Bar -->
        <div class="flex items-center justify-between bg-white dark:bg-slate-800 p-4 rounded-lg shadow-sm mb-6 mt-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{game.title}</h1>
                <div class="text-sm text-gray-500">
                    <span class="mr-3">{t('game.plays')}: {game.plays?.toLocaleString()}</span>
                    <span>{t('game.rating')}: {game.rating}/5</span>
                </div>
            </div>
            <div class="flex gap-2">
                 <button id="favoriteBtn" data-slug={game.slug} data-text-favorite={t('game.favorite')} data-text-favorited="Guardado" class="btn-secondary px-3 py-1.5 text-sm rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">🤍 {t('game.favorite')}</button>
                 <button id="shareBtn" class="btn-secondary px-3 py-1.5 text-sm rounded border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700">🔗 {t('game.share')}</button>
            </div>
        </div>

        <!-- Game Description -->
        <div class="prose dark:prose-invert max-w-none bg-white dark:bg-slate-800 p-6 rounded-lg shadow-sm">
            <h3>{t('game.about')} {game.title}</h3>
            <p>{game.description}</p>
            <p>{t('game.description', [game.title, translatedCategory])}</p>
            
            <h4>{t('game.howToPlay')}</h4>
            <p>Use keyboard arrows or WASD to control. Space to jump/action.</p>
        </div>
      </div>

      <!-- Sidebar (1/3 width) -->
      <div class="lg:col-span-1">
        <div class="bg-white dark:bg-slate-800 p-4 rounded-lg shadow-sm sticky top-24">
            <h3 class="font-bold text-lg mb-4 border-b pb-2">{t('game.similar')}</h3>
            <div class="flex flex-col gap-4">
                {relatedGames.slice(0, 6).map(related => (
                    <a href={`/es/game/${related.id}-${related.slug}`} class="flex gap-3 group">
                        <img src={related.thumbnail} alt={related.title} class="w-20 h-14 object-cover rounded bg-gray-200" />
                        <div>
                            <div class="font-bold text-sm group-hover:text-primary transition">{related.title}</div>
                            <div class="text-xs text-gray-500">{getTranslatedCategory(related.category)} • ⭐ {related.rating}</div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
      </div>

    </div>
  </WidgetWrapper>

  <!-- More Games Grid -->
  <GameGrid
    title={t('game.youMightLike')}
    games={relatedGames}
    classes={{ container: 'py-8 lg:py-12' }}
  />

  <!-- Schema.org -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": game.title,
    "description": game.description,
    "genre": [game.category],
    "url": Astro.url.href,
    "image": game.thumbnail,
    "playMode": "SinglePlayer",
    "applicationCategory": "Browser Game",
    "operatingSystem": "Any",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": game.rating,
      "ratingCount": 100,
      "bestRating": "5",
      "worstRating": "1"
    },
    "inLanguage": "es"
  })} />

  <script>
    import { toggleFavorite, isFavorite, addToHistory } from '~/stores/gameState';
  
    const initGamePage = () => {
      const favoriteBtn = document.getElementById('favoriteBtn');
      const shareBtn = document.getElementById('shareBtn');
      
      // Favorite Logic
      if (favoriteBtn) {
          const slug = favoriteBtn.getAttribute('data-slug');
          const favoriteText = favoriteBtn.getAttribute('data-text-favorite') || 'Favorite';
          const favoritedText = favoriteBtn.getAttribute('data-text-favorited') || 'Saved';
          
          const updateBtn = () => {
              if (!slug) return;
              const isFav = isFavorite(slug);
              favoriteBtn.textContent = isFav ? `❤️ ${favoritedText}` : `🤍 ${favoriteText}`;
              if (isFav) {
                  favoriteBtn.classList.add('text-pink-600', 'border-pink-200', 'bg-pink-50');
              } else {
                  favoriteBtn.classList.remove('text-pink-600', 'border-pink-200', 'bg-pink-50');
              }
          };
  
          favoriteBtn.onclick = () => {
              if (slug) {
                  toggleFavorite(slug);
                  updateBtn();
              }
          };
          
          updateBtn();

          // Add to history
          if (slug) {
             setTimeout(() => {
                 addToHistory(slug);
             }, 5000);
          }
      }
  
      // Share Logic
      if (shareBtn) {
          shareBtn.onclick = async () => {
              if (navigator.share) {
                  try {
                      await navigator.share({
                          title: document.title,
                          url: window.location.href
                      });
                  } catch (err) {
                      console.error('Share failed:', err);
                  }
              } else {
                  // Fallback to clipboard
                  try {
                      await navigator.clipboard.writeText(window.location.href);
                      const originalText = shareBtn.textContent;
                      shareBtn.textContent = '✅ Copiado!';
                      setTimeout(() => {
                          shareBtn.textContent = originalText;
                      }, 2000);
                  } catch (err) {
                      console.error('Clipboard failed:', err);
                  }
              }
          };
      }
    };
  
    document.addEventListener('astro:page-load', initGamePage);
  </script>
</Layout>
