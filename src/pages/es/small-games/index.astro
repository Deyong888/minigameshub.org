---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { mainSmallGames } from '~/data/games';

const metadata = {
  title: 'Juegos Pequeños - Ligeros y Rápidos',
  description: 'Juega juegos pequeños que cargan al instante. Perfectos para conexiones lentas o diversión rápida.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Juegos Pequeños",
  "description": metadata.description,
  "url": "https://minigameshub.org/es/small-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": mainSmallGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/es/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Inicio
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Juegos Pequeños</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Juegos Pequeños
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Juegos ligeros que cargan rápido y funcionan suavemente.
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/es/small-games/casual" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Casuales</a>
      <a href="/es/small-games/quick" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Rápidos</a>
      <a href="/es/small-games/short" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">Cortos</a>
    </div>

    <div class="mt-8 mb-12">
      <h2 class="text-2xl font-bold mb-8 text-center">Explora Categorías de Juegos Pequeños</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/es/small-games/casual" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-600 dark:text-indigo-300 group-hover:bg-indigo-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Casuales</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Fáciles de jugar, difíciles de dejar.</p>
        </a>

        <a href="/es/small-games/quick" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-orange-100 dark:bg-orange-900 text-orange-600 dark:text-orange-300 group-hover:bg-orange-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Rápidos</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Acción instantánea sin esperas.</p>
        </a>

        <a href="/es/small-games/short" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-purple-100 dark:bg-purple-900 text-purple-600 dark:text-purple-300 group-hover:bg-purple-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">Cortos</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">Perfectos para pausas breves.</p>
        </a>
      </div>
    </div>

    <GameGrid games={mainSmallGames} />
    
    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Diversión Ligera y Rápida</h2>
      <p>
        Los juegos pequeños son la solución perfecta para cuando quieres jugar pero no tienes mucho tiempo o una conexión a internet ultra rápida. Optimizados para cargar casi instantáneamente, estos juegos se centran en la jugabilidad pura sin descargas pesadas ni tiempos de carga largos.
      </p>
      <h3>Ventajas de los Juegos Pequeños</h3>
      <ul>
        <li><strong>Carga Instantánea:</strong> Empieza a jugar en segundos, no minutos.</li>
        <li><strong>Bajo Consumo de Datos:</strong> Ideales para jugar en móviles con planes de datos limitados.</li>
        <li><strong>Accesibilidad:</strong> Funcionan bien incluso en dispositivos más antiguos.</li>
      </ul>
    </div>
  </section>
</Layout>

