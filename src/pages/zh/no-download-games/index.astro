---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { noDownloadGames } from '~/data/games';

const metadata = {
  title: '无需下载的游戏 - 免费即点即玩 | MiniGamesHub',
  description: '无需下载即可立即畅玩免费游戏。我们的无需下载游戏非常适合在工作或学校进行快速娱乐。零安装，100% 免费。',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "无需下载的游戏",
  "description": metadata.description,
  "url": "https://minigameshub.org/zh/no-download-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": noDownloadGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/zh/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game",
        "inLanguage": "zh"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/zh/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            首页
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">无需下载的游戏</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      无需下载的游戏
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      无需等待，即刻体验乐趣。点击即玩。
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/zh/no-download-games/instant-play" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">即点即玩</a>
      <a href="/zh/no-download-games/play-now" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">现在就开始</a>
      <a href="/zh/no-download-games/zero-install" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">零安装</a>
    </div>

    <GameGrid games={noDownloadGames} />

    <div class="mt-16">
      <h2 class="text-3xl font-bold font-heading mb-8 text-center">探索无需下载分类</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <a href="/zh/no-download-games/instant-play" class="group relative overflow-hidden rounded-lg p-6 bg-white dark:bg-slate-800 shadow-md hover:shadow-lg transition text-center border border-gray-200 dark:border-slate-700">
          <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition">即点即玩</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">直接进入游戏世界</p>
        </a>
        <a href="/zh/no-download-games/play-now" class="group relative overflow-hidden rounded-lg p-6 bg-white dark:bg-slate-800 shadow-md hover:shadow-lg transition text-center border border-gray-200 dark:border-slate-700">
          <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition">现在就开始</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">无需注册，即刻畅玩</p>
        </a>
        <a href="/zh/no-download-games/zero-install" class="group relative overflow-hidden rounded-lg p-6 bg-white dark:bg-slate-800 shadow-md hover:shadow-lg transition text-center border border-gray-200 dark:border-slate-700">
          <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition">零安装</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">保持您的设备整洁</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
