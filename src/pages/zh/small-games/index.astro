---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { mainSmallGames } from '~/data/games';

const metadata = {
  title: '小游戏 - 轻量且快速 | MiniGamesHub',
  description: '畅玩能瞬间加载的小游戏。非常适合慢速网络或快速娱乐。',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "小游戏",
  "description": metadata.description,
  "url": "https://minigameshub.org/zh/small-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": mainSmallGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/zh/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game",
        "inLanguage": "zh"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/zh/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            首页
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">小游戏</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      小游戏
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      加载迅速、运行流畅的轻量级游戏。
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/zh/small-games/casual" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">休闲</a>
      <a href="/zh/small-games/quick" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">快速</a>
      <a href="/zh/small-games/short" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">短平快</a>
    </div>

    <div class="mt-8 mb-12">
      <h2 class="text-2xl font-bold mb-8 text-center">探索小游戏分类</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/zh/small-games/casual" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-600 dark:text-indigo-300 group-hover:bg-indigo-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">休闲</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">易于上手，欲罢不能。</p>
        </a>

        <a href="/zh/small-games/quick" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-orange-100 dark:bg-orange-900 text-orange-600 dark:text-orange-300 group-hover:bg-orange-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">快速</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">即时行动，无需等待。</p>
        </a>

        <a href="/zh/small-games/short" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-purple-100 dark:bg-purple-900 text-purple-600 dark:text-purple-300 group-hover:bg-purple-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">短平快</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">短促休息时间的完美选择。</p>
        </a>
      </div>
    </div>

    <GameGrid games={mainSmallGames} />
    
    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>轻量且快速的娱乐</h2>
      <p>
        当您想玩游戏但时间有限，或者没有超高速的网络连接时，小游戏是完美的解决方案。这些游戏经过优化，几乎可以瞬间加载，专注于纯粹的游戏玩法，无需繁重的下载或冗长的加载时间。
      </p>
      <h3>小游戏的优势</h3>
      <ul>
        <li><strong>瞬间加载：</strong> 几秒钟内即可开始游戏，而非几分钟。</li>
        <li><strong>低流量消耗：</strong> 非常适合流量套餐有限的手机用户。</li>
        <li><strong>兼容性强：</strong> 即使在旧设备上也能流畅运行。</li>
      </ul>
    </div>
  </section>
</Layout>
