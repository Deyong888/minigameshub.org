---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { mainRelaxGames } from '~/data/games';

const metadata = {
  title: '放松游戏 - 缓解压力与宁静体验 | MiniGamesHub',
  description: '通过我们的放松游戏系列放松身心。宁静、平和且无压力的网页游戏。',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "放松游戏",
  "description": metadata.description,
  "url": "https://minigameshub.org/zh/relax-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": mainRelaxGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/zh/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game",
        "inLanguage": "zh"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/zh/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            首页
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">放松游戏</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      放松游戏
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      宁静的游戏体验，助您放松身心，缓解压力。
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/zh/relax-games/stress-relief" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">缓解压力</a>
      <a href="/zh/relax-games/calming" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">宁静放松</a>
      <a href="/zh/relax-games/casual" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">休闲游戏</a>
    </div>

    <div class="mt-8 mb-12">
      <h2 class="text-2xl font-bold mb-8 text-center">探索放松游戏分类</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/zh/relax-games/stress-relief" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 group-hover:bg-blue-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">缓解压力</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">通过令人满意的游戏机制释放紧张情绪。</p>
        </a>

        <a href="/zh/relax-games/calming" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-teal-100 dark:bg-teal-900 text-teal-600 dark:text-teal-300 group-hover:bg-teal-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">宁静放松</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">禅意体验与宁静的氛围。</p>
        </a>

        <a href="/zh/relax-games/casual" class="block p-6 bg-white dark:bg-slate-900 rounded-lg shadow hover:shadow-lg transition border border-gray-200 dark:border-gray-700 group">
          <div class="flex items-center mb-4">
            <div class="p-3 rounded-full bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-300 group-hover:bg-green-600 group-hover:text-white transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="ml-4 text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition">休闲游戏</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-400">毫无压力的轻松游戏。</p>
        </a>
      </div>
    </div>

    <GameGrid games={mainRelaxGames} />
    
    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>寻找内心的宁静</h2>
      <p>
        在当今快节奏的世界里，花点时间放松至关重要。我们的放松游戏系列旨在为您提供一个远离日常压力的宁静避风港。无论您是寻求令人满意的压力释放，还是宁静的解谜过程，这里都能找到您的数字圣地。
      </p>
      <h3>放松游戏的好处</h3>
      <ul>
        <li><strong>减轻压力：</strong> 专为缓解焦虑而设计的游戏机制。</li>
        <li><strong>正念：</strong> 通过柔和的游戏过程专注于当下。</li>
        <li><strong>无压力：</strong> 无需担心时间限制或高分压力。</li>
      </ul>
    </div>
  </section>
</Layout>
