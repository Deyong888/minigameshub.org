---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { arcadeModernGames } from '~/data/games';

const metadata = {
  title: '现代街机游戏 - 新时代的乐趣',
  description: '现代游戏中的街机精神。高质量图形与令人上瘾的玩法完美结合。',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "现代街机游戏",
  "description": metadata.description,
  "url": "https://minigameshub.org/zh/arcade-games/modern",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": arcadeModernGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/zh/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game",
        "inLanguage": "zh"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/zh/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            首页
          </a>
        </li>
        <li class="inline-flex items-center">
          <a href="/zh/arcade-games" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            街机游戏
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">现代</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      现代街机游戏
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      融入现代技术的街机精神。
    </p>
    <GameGrid games={arcadeModernGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>街机的演化</h2>
      <p>
        现代街机游戏将经典作品中让人上瘾的玩法与当今的图形技术相结合。
        在保持高分竞技和快节奏动作精神的同时，这些作品利用现代硬件提供令人惊叹的视觉体验。
      </p>
      <h3>现代特色</h3>
      <p>
        不只是华丽的外表，游戏性也在不断进化。
      </p>
      <ul>
        <li><strong>高清图形：</strong> 细腻的视觉效果、粒子特效和流畅的动画。</li>
        <li><strong>全新机制：</strong> 对经典类型进行创新设计，提升游戏深度。</li>
        <li><strong>跨平台支持：</strong> 在桌面端和移动端都能完美运行。</li>
      </ul>
    </div>
  </section>
</Layout>
