---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { html5Games } from '~/data/games';

const metadata = {
  title: 'HTML5 游戏 - 免费畅玩现代网页游戏',
  description: '享受可在任何设备上畅玩的最佳 HTML5 游戏。这些游戏兼容移动端、支持跨平台且具备离线功能，可在浏览器中流畅运行。',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "HTML5 游戏",
  "description": metadata.description,
  "url": "https://minigameshub.org/zh/html5-games",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": html5Games.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/zh/game/${game.id}-${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game",
        "inLanguage": "zh"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/zh/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            首页
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">HTML5 游戏</span>
          </div>
        </li>
      </ol>
    </nav>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      HTML5 游戏
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      现代、快速且精美的游戏，随时随地开启。
    </p>

    <!-- Categories Cloud -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <a href="/zh/html5-games/mobile-friendly" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">兼容移动端</a>
      <a href="/zh/html5-games/cross-platform" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">跨平台</a>
      <a href="/zh/html5-games/offline-capable" class="px-3 py-1 bg-gray-100 dark:bg-slate-700 rounded-full text-sm hover:bg-primary hover:text-white transition capitalize">离线模式</a>
    </div>

    <GameGrid games={html5Games} />

    <div class="mt-16">
      <h2 class="text-2xl font-bold mb-8 text-center">探索 HTML5 游戏分类</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/zh/html5-games/mobile-friendly" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">兼容移动端</h3>
          <p class="text-gray-600 dark:text-gray-400">专为触摸屏和手机优化的游戏。</p>
        </a>
        <a href="/zh/html5-games/cross-platform" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">跨平台</h3>
          <p class="text-gray-600 dark:text-gray-400">在电脑、平板或手机上畅玩，不丢失进度。</p>
        </a>
        <a href="/zh/html5-games/offline-capable" class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow hover:shadow-lg transition border border-gray-100 dark:border-gray-700">
          <h3 class="text-xl font-bold mb-2 text-primary">离线模式</h3>
          <p class="text-gray-600 dark:text-gray-400">即使没有互联网连接也能运行的游戏。</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
