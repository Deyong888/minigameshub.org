---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { getUniqueCategories, getGamesByCategory } from '~/data/games';
import { getLangFromUrl, useTranslations } from '~/utils/i18n';

export async function getStaticPaths() {
  const categories = getUniqueCategories();
  
  return categories.map((category) => ({
    params: { slug: category.toLowerCase().replace(/\s+/g, '-') },
    props: { category, games: getGamesByCategory(category) },
  }));
}

const { category, games } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Helper to get translated category name
const getTranslatedCategory = (cat: string) => {
    // Try to find translation for 'cat.categoryname'
    const key = `cat.${cat.toLowerCase()}`;
    // Use 'as any' to bypass strict type checking for dynamic keys
    const translated = (t as any)(key);
    
    // If translation exists and isn't just undefined (useTranslations logic handles fallback to en, but if key missing in en too?)
    // Our useTranslations returns undefined if missing in both.
    if (translated) return translated;
    
    // Fallback to capitalizing the original category
    return cat.charAt(0).toUpperCase() + cat.slice(1);
};

const translatedCategory = getTranslatedCategory(category);

const metadata = {
  title: `${translatedCategory}游戏 - 在线免费玩`,
  description: `在 MiniGamesHub.org 免费在线玩最好的${translatedCategory}游戏。无需下载，即点即玩。`,
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{
      "@type": "ListItem",
      "position": 1,
      "name": "首页",
      "item": "https://minigameshub.org/zh"
    },{
      "@type": "ListItem",
      "position": 2,
      "name": "迷你游戏",
      "item": "https://minigameshub.org/zh/mini-games" 
    },{
      "@type": "ListItem",
      "position": 3,
      "name": translatedCategory,
      "item": Astro.url.href
    }]
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": metadata.title,
    "description": metadata.description,
    "url": Astro.url.href,
    "inLanguage": "zh",
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": games.slice(0, 20).map((game, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "url": `https://minigameshub.org/zh/game/${game.id}-${game.slug}`,
        "name": game.title
      }))
    }
  }
];
---

<Layout metadata={metadata}>
  {jsonLd.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
  
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="text-center mb-12">
      <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 capitalize">
        {translatedCategory}游戏
      </h1>
      <p class="text-xl text-muted">
        在线免费玩最好的 <strong>{translatedCategory}游戏</strong>。
        <br/>
        浏览器即点即玩，无需下载，尽享乐趣。
      </p>
    </div>
    
    <div class="mb-8">
        <a href="/zh/mini-games" class="text-primary hover:underline">← 返回迷你游戏</a>
    </div>

    <GameGrid games={games} />
  </section>
</Layout>
