---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { browserGames } from '~/data/games';

const metadata = {
  title: 'WebGL Games - 3D Browser Games | MiniGamesHub',
  description: 'Play stunning 3D WebGL games in your browser. Experience high-quality graphics and immersive gameplay without any downloads.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "WebGL Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/browser-games/webgl",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": browserGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/browser-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">Browser Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">WebGL</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      WebGL Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Immersive 3D experiences directly in your browser.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>What are WebGL Games?</h3>
      <p>WebGL (Web Graphics Library) allows browsers to render high-performance 3D graphics without plugins. This means you can play console-quality 3D games right here on MiniGamesHub.</p>
      <ul>
        <li><strong>Stunning Graphics:</strong> Real 3D rendering in your browser.</li>
        <li><strong>Smooth Performance:</strong> Hardware-accelerated for fast gameplay.</li>
        <li><strong>No Downloads:</strong> Just click and play, no installation required.</li>
      </ul>
    </div>

    <GameGrid games={browserGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>Next-Gen Graphics with WebGL Games</h2>
      <p>
        WebGL (Web Graphics Library) is a JavaScript API that lets browsers render high-performance interactive 3D and 2D graphics.
        This technology brings console-quality visuals directly to your web browser. Our WebGL games feature advanced lighting, physics simulations, and complex 3D models that were previously impossible on the web.
      </p>
      
      <h3>Why Play WebGL Games?</h3>
      <p>
        If you are looking for a more immersive gaming experience, WebGL is the answer.
      </p>
      <ul>
        <li><strong>3D Immersion:</strong> Explore fully realized 3D worlds, from racing tracks to open-world adventures.</li>
        <li><strong>Hardware Acceleration:</strong> Utilizes your device's GPU for smooth frame rates and detailed textures.</li>
        <li><strong>Complex Gameplay:</strong> Supports deeper mechanics found in downloadable PC games, such as first-person shooters (FPS) and driving simulators.</li>
      </ul>
      
      <h3>System Requirements</h3>
      <p>
        While WebGL games are powerful, they are also optimized. Most modern computers and smartphones can run them easily. For the best experience, we recommend using an updated browser like Google Chrome or Mozilla Firefox and ensuring your graphics drivers are up to date.
      </p>
    </div>
  </section>
</Layout>
