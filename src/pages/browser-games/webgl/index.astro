---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { browserGames } from '~/data/games';

const metadata = {
  title: 'WebGL Games - 3D Browser Games | MiniGamesHub',
  description: 'Play stunning 3D WebGL games in your browser. Experience high-quality graphics and immersive gameplay without any downloads.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "WebGL Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/browser-games/webgl",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": browserGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="text-sm text-gray-500 mb-4 text-center">
      <a href="/" class="hover:text-primary">Home</a> &gt; 
      <a href="/browser-games" class="hover:text-primary">Browser Games</a> &gt; 
      <span class="font-bold text-gray-700 dark:text-gray-300">WebGL</span>
    </div>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      WebGL Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Immersive 3D experiences directly in your browser.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>What are WebGL Games?</h3>
      <p>WebGL (Web Graphics Library) allows browsers to render high-performance 3D graphics without plugins. This means you can play console-quality 3D games right here on MiniGamesHub.</p>
      <ul>
        <li><strong>Stunning Graphics:</strong> Real 3D rendering in your browser.</li>
        <li><strong>Smooth Performance:</strong> Hardware-accelerated for fast gameplay.</li>
        <li><strong>No Downloads:</strong> Just click and play, no installation required.</li>
      </ul>
    </div>

    <GameGrid games={browserGames} />
  </section>
</Layout>
