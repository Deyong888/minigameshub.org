---
import Layout from '~/layouts/PageLayout.astro';
import GameGrid from '~/components/widgets/GameGrid.astro';
import { browserGames } from '~/data/games';

const metadata = {
  title: 'Flash Alternative Games - Play Without Flash Player | MiniGamesHub',
  description: 'Play the best alternatives to Flash games. Enjoy classic-style browser games preserved and remade for modern browsers using HTML5 and emulators.',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Flash Alternative Games",
  "description": metadata.description,
  "url": "https://minigameshub.org/browser-games/flash-alternative",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": browserGames.map((game, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VideoGame",
        "name": game.title,
        "url": `https://minigameshub.org/game/${game.slug}`,
        "image": game.thumbnail,
        "description": game.description,
        "genre": game.category,
        "playMode": "SinglePlayer",
        "applicationCategory": "Game"
      }
    }))
  }
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
            <svg class="w-3 h-3 mr-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            Home
          </a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <a href="/browser-games" class="ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white md:ml-2">Browser Games</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">Flash Alternatives</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter mb-4 font-heading text-center">
      Flash Alternative Games
    </h1>
    <p class="text-xl text-muted mb-8 text-center">
      Keeping the spirit of classic Flash gaming alive.
    </p>

    <div class="prose dark:prose-invert max-w-none mb-12 bg-blue-50 dark:bg-slate-800 p-6 rounded-lg">
      <h3>Life After Flash</h3>
      <p>Adobe Flash Player may be gone, but the games live on. We offer a huge collection of HTML5 games that capture the fun and simplicity of the golden age of Flash gaming.</p>
      <ul>
        <li><strong>Safe & Secure:</strong> Modern technology without the security risks of Flash.</li>
        <li><strong>Works Everywhere:</strong> Play on mobile and tablet, not just desktop.</li>
        <li><strong>Classic Feel:</strong> Enjoy the same genres: arcade, puzzle, and dress-up.</li>
      </ul>
    </div>

    <GameGrid games={browserGames} />

    <div class="mt-16 prose dark:prose-invert max-w-none">
      <h2>The Best Flash Game Alternatives in 2025</h2>
      <p>
        The era of Adobe Flash may have ended, but the legacy of Flash gaming continues to thrive through modern alternatives. 
        At MiniGamesHub, we preserve the essence of these classic experiences using cutting-edge technologies like HTML5, WebGL, and WebAssembly.
        Our collection of Flash alternative games ensures that you can still enjoy the addictive gameplay, quirky humor, and simple fun that defined a generation of internet culture.
      </p>
      
      <h3>How to Play Flash Games Without Flash Player</h3>
      <p>
        You no longer need to install unsafe plugins or worry about security vulnerabilities. All games on this page are fully playable directly in your modern web browser.
        We use advanced emulation and porting techniques to bring you:
      </p>
      <ul>
        <li><strong>Ruffle Emulator Support:</strong> Many classics run seamlessly via Ruffle.</li>
        <li><strong>Native HTML5 Ports:</strong> Remade versions of popular hits with better performance.</li>
        <li><strong>Cross-Platform Compatibility:</strong> Play on Windows, macOS, Linux, and often on mobile devices.</li>
      </ul>
      
      <h3>Frequently Asked Questions</h3>
      <h4>Are these games safe to play?</h4>
      <p>Yes! Since they don't require the actual Flash Player plugin, they are free from the security risks associated with the old technology.</p>
      
      <h4>Do I need to download anything?</h4>
      <p>No. Just click and play. All necessary code runs within your browser's secure sandbox.</p>
    </div>
  </section>
</Layout>
